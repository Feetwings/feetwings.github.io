mits!</h1>\n            <p className=\"paragraph\"><span>Feetwings<sup>TM</sup></span> is an app that helps you organize\n              yourself on the daily basis using systematic\n              algorithms to achieve success.</p>\n            <div className=\"download-buttons\">\n              <a href=\"/\" className=\"google-play\">\n                <i className=\"fab fa-google-play\"></i>\n                <div className=\"button-content\">\n                  <h6>GET IT ON <span>Google Play</span></h6>\n                </div>\n              </a>\n              <a href=\"/\" className=\"apple-store\">\n                <i className=\"fab fa-apple\"></i>\n                <div className=\"button-content\">\n                  <h6>GET IT ON <span>Apple Store</span></h6>\n                </div>\n              </a>\n            </div>\n          </div>\n          <div className=\"col-lg-6 order-1 order-lg-2\">\n            <div className=\"questions-img hero-img\">\n              <img ref={img} src={appimg} alt=\"image\"></img>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n        \n    );\n}\n\nexport default Home;","/Users/aryasoni/Documents/GitHub/feetwings.github.io/src/components/UI/sideDrawer/sideDrawer.js",[],"/Users/aryasoni/Documents/GitHub/feetwings.github.io/src/components/hamburgerIcon/hamburger.js",[],"/Users/aryasoni/Documents/GitHub/feetwings.github.io/src/components/UI/Overlay/overlay.js",[],{"ruleId":"44","severity":1,"message":"45","line":42,"column":15,"nodeType":"46","endLine":42,"endColumn":55},"jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","JSXOpeningElement"]